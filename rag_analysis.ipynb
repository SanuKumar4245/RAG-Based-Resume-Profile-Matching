 "cells": [
  {
   "metadata": {},
   "cell_type": "raw",
   "source": [
    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\"# RAG-Based Resume Profile Matching — Analysis & Experimentation\\n\", \"\\n\", \"End-to-end pipeline: indexing resumes, hybrid semantic+BM25 matching, performance metrics.\"]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import sys, os, json, time\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"import seaborn as sns\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"\\n\",\n",
    "    \"sns.set_theme(style='whitegrid')\\n\",\n",
    "    \"%matplotlib inline\\n\",\n",
    "    \"\\n\",\n",
    "    \"sys.path.insert(0, str(Path().resolve()))\\n\",\n",
    "    \"print('Python:', sys.version)\\n\",\n",
    "    \"print('Working dir:', os.getcwd())\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\"## 1. Index Resumes into ChromaDB Vector Store\"]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"from resume_rag import ResumeRAG\\n\",\n",
    "    \"\\n\",\n",
    "    \"rag = ResumeRAG(resumes_dir='resumes', db_path='./chroma_db')\\n\",\n",
    "    \"stats = rag.index_all()\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Resumes indexed : {stats['resumes_indexed']}\\\")\\n\",\n",
    "    \"print(f\\\"Total chunks    : {stats['total_chunks']}\\\")\\n\",\n",
    "    \"print(f\\\"Collection size : {stats['collection_size']}\\\")\\n\",\n",
    "    \"print(f\\\"Elapsed (s)     : {stats['elapsed_seconds']}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"col_stats = rag.get_collection_stats()\\n\",\n",
    "    \"print(f\\\"Candidates indexed: {col_stats['total_candidates']}\\\")\\n\",\n",
    "    \"for c in col_stats['candidates']:\\n\",\n",
    "    \"    print(' ', c)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\"## 2. Single JD Match Demo — Senior ML Engineer\"]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"from job_matcher import JobMatcher\\n\",\n",
    "    \"\\n\",\n",
    "    \"matcher = JobMatcher(resumes_dir='resumes', db_path='./chroma_db')\\n\",\n",
    "    \"result = matcher.match_from_file('job_descriptions/jd_senior_ml_engineer.txt', top_k=10)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Retrieval latency: {result['retrieval_latency_seconds']}s\\\\n\\\")\\n\",\n",
    "    \"print(f\\\"{'Rank':<5} {'Score':<7} {'Candidate':<28} {'Matched Skills'}\\\")\\n\",\n",
    "    \"print('-' * 75)\\n\",\n",
    "    \"for i, m in enumerate(result['top_matches'], 1):\\n\",\n",
    "    \"    skills = ', '.join(m['matched_skills'][:4])\\n\",\n",
    "    \"    print(f\\\"{i:<5} {m['match_score']:<7} {m['candidate_name']:<28} {skills}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"top = result['top_matches'][0]\\n\",\n",
    "    \"print(json.dumps(top, indent=2))\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\"## 3. Batch Evaluation — All 6 Job Descriptions\"]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"jd_files = sorted(Path('job_descriptions').glob('*.txt'))\\n\",\n",
    "    \"all_results, latencies = {}, []\\n\",\n",
    "    \"\\n\",\n",
    "    \"for jd_file in jd_files:\\n\",\n",
    "    \"    res = matcher.match_from_file(str(jd_file), top_k=10)\\n\",\n",
    "    \"    all_results[jd_file.stem] = res\\n\",\n",
    "    \"    latencies.append(res['retrieval_latency_seconds'])\\n\",\n",
    "    \"    t1 = res['top_matches'][0]\\n\",\n",
    "    \"    print(f\\\"{jd_file.stem:<40} {res['retrieval_latency_seconds']:.3f}s  -> {t1['candidate_name']} ({t1['match_score']})\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"\\\\nAvg latency: {np.mean(latencies):.3f}s | Max: {np.max(latencies):.3f}s\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"rows = []\\n\",\n",
    "    \"for jd_name, res in all_results.items():\\n\",\n",
    "    \"    for m in res['top_matches']:\\n\",\n",
    "    \"        rows.append({'job': jd_name, 'candidate': m['candidate_name'],\\n\",\n",
    "    \"                     'score': m['match_score'], 'n_skills': len(m['matched_skills'])})\\n\",\n",
    "    \"df = pd.DataFrame(rows)\\n\",\n",
    "    \"print(df.groupby('job')['score'].describe().round(2))\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\"## 4. Visualizations\"]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"fig, axes = plt.subplots(1, 2, figsize=(14, 5))\\n\",\n",
    "    \"\\n\",\n",
    "    \"df['score'].plot(kind='hist', bins=20, ax=axes[0], color='steelblue', edgecolor='white')\\n\",\n",
    "    \"axes[0].set_title('Match Score Distribution (All JDs, Top-10)')\\n\",\n",
    "    \"axes[0].set_xlabel('Match Score (0-100)')\\n\",\n",
    "    \"axes[0].axvline(df['score'].mean(), color='red', linestyle='--', label=f\\\"Mean={df['score'].mean():.1f}\\\")\\n\",\n",
    "    \"axes[0].legend()\\n\",\n",
    "    \"\\n\",\n",
    "    \"labels = [j.replace('jd_','').replace('_',' ').title() for j in all_results]\\n\",\n",
    "    \"axes[1].barh(labels, latencies, color='coral', edgecolor='white')\\n\",\n",
    "    \"axes[1].set_title('Retrieval Latency per Job Description')\\n\",\n",
    "    \"axes[1].set_xlabel('Seconds')\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.savefig('score_distribution.png', dpi=120, bbox_inches='tight')\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"pivot = df.pivot_table(index='candidate', columns='job', values='score', fill_value=0)\\n\",\n",
    "    \"pivot.columns = [c.replace('jd_','').replace('_',' ').title() for c in pivot.columns]\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.figure(figsize=(14, max(6, len(pivot)*0.38)))\\n\",\n",
    "    \"sns.heatmap(pivot, annot=True, fmt='.0f', cmap='YlOrRd', linewidths=0.4,\\n\",\n",
    "    \"            cbar_kws={'label': 'Match Score'}, vmin=0, vmax=100)\\n\",\n",
    "    \"plt.title('Candidate × Job Match Score Heatmap', fontsize=14)\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.savefig('score_heatmap.png', dpi=120, bbox_inches='tight')\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"n = len(all_results)\\n\",\n",
    "    \"cols = 3\\n\",\n",
    "    \"rows_grid = (n + cols - 1) // cols\\n\",\n",
    "    \"fig, axes = plt.subplots(rows_grid, cols, figsize=(18, rows_grid * 4))\\n\",\n",
    "    \"axes = axes.flatten()\\n\",\n",
    "    \"\\n\",\n",
    "    \"for i, (jd_name, res) in enumerate(all_results.items()):\\n\",\n",
    "    \"    top5 = res['top_matches'][:5]\\n\",\n",
    "    \"    names = [m['candidate_name'] for m in top5]\\n\",\n",
    "    \"    scores = [m['match_score'] for m in top5]\\n\",\n",
    "    \"    colors = plt.cm.RdYlGn(np.array(scores) / 100)\\n\",\n",
    "    \"    axes[i].barh(names[::-1], scores[::-1], color=colors[::-1])\\n\",\n",
    "    \"    axes[i].set_xlim(0, 105)\\n\",\n",
    "    \"    axes[i].set_title(jd_name.replace('jd_','').replace('_',' ').title(), fontsize=11)\\n\",\n",
    "    \"    for j, s in enumerate(scores[::-1]):\\n\",\n",
    "    \"        axes[i].text(s+1, j, str(s), va='center', fontsize=9)\\n\",\n",
    "    \"\\n\",\n",
    "    \"for j in range(i+1, len(axes)):\\n\",\n",
    "    \"    fig.delaxes(axes[j])\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.suptitle('Top 5 Candidates per Job Description', fontsize=14)\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.savefig('top5_per_jd.png', dpi=120, bbox_inches='tight')\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\"## 5. Hybrid Weight Tuning\"]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"with open('job_descriptions/jd_senior_ml_engineer.txt') as f:\\n\",\n",
    "    \"    ml_jd = f.read()\\n\",\n",
    "    \"\\n\",\n",
    "    \"weights = np.arange(0.2, 1.05, 0.1)\\n\",\n",
    "    \"sweep = []\\n\",\n",
    "    \"for sw in weights:\\n\",\n",
    "    \"    bw = round(1.0 - sw, 2)\\n\",\n",
    "    \"    m = JobMatcher('resumes', './chroma_db', semantic_weight=round(sw,2), bm25_weight=bw)\\n\",\n",
    "    \"    res = m.match(ml_jd, top_k=5)\\n\",\n",
    "    \"    t1 = res['top_matches'][0] if res['top_matches'] else {}\\n\",\n",
    "    \"    sweep.append({'semantic_w': round(sw,2), 'bm25_w': bw,\\n\",\n",
    "    \"                  'top1': t1.get('candidate_name',''), 'score': t1.get('match_score',0),\\n\",\n",
    "    \"                  'latency': res['retrieval_latency_seconds']})\\n\",\n",
    "    \"\\n\",\n",
    "    \"sw_df = pd.DataFrame(sweep)\\n\",\n",
    "    \"print(sw_df.to_string(index=False))\\n\",\n",
    "    \"sw_df.to_csv('weight_tuning.csv', index=False)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"fig, ax1 = plt.subplots(figsize=(10, 5))\\n\",\n",
    "    \"ax1.plot(sw_df['semantic_w'], sw_df['score'], 'o-', color='steelblue', label='Top-1 Score')\\n\",\n",
    "    \"ax1.set_xlabel('Semantic Weight')\\n\",\n",
    "    \"ax1.set_ylabel('Top-1 Match Score', color='steelblue')\\n\",\n",
    "    \"ax1.axvline(0.6, color='gray', linestyle=':', label='Default (0.6)')\\n\",\n",
    "    \"ax2 = ax1.twinx()\\n\",\n",
    "    \"ax2.plot(sw_df['semantic_w'], sw_df['latency'], 's--', color='coral', label='Latency (s)')\\n\",\n",
    "    \"ax2.set_ylabel('Latency (s)', color='coral')\\n\",\n",
    "    \"lines = ax1.get_lines() + ax2.get_lines()\\n\",\n",
    "    \"ax1.legend(lines, [l.get_label() for l in lines], loc='lower right')\\n\",\n",
    "    \"plt.title('Hybrid Weight Sweep — Senior ML Engineer JD')\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.savefig('weight_sweep.png', dpi=120, bbox_inches='tight')\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\"## 6. Performance Metrics Summary\"]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"top1_scores = [r['top_matches'][0]['match_score'] for r in all_results.values() if r['top_matches']]\\n\",\n",
    "    \"\\n\",\n",
    "    \"print('=== Performance Metrics ===')\\n\",\n",
    "    \"print(f\\\"JDs evaluated            : {len(all_results)}\\\")\\n\",\n",
    "    \"print(f\\\"Candidates indexed       : {col_stats['total_candidates']}\\\")\\n\",\n",
    "    \"print(f\\\"Total chunks in store    : {col_stats['total_chunks']}\\\")\\n\",\n",
    "    \"print(f\\\"Avg retrieval latency    : {np.mean(latencies):.3f}s\\\")\\n\",\n",
    "    \"print(f\\\"P95 retrieval latency    : {np.percentile(latencies, 95):.3f}s\\\")\\n\",\n",
    "    \"print(f\\\"Avg top-1 match score    : {np.mean(top1_scores):.1f}\\\")\\n\",\n",
    "    \"print(f\\\"Min / Max top-1 score    : {np.min(top1_scores):.1f} / {np.max(top1_scores):.1f}\\\")\\n\",\n",
    "    \"print(f\\\"Top-1 accuracy (>60)     : {sum(s>60 for s in top1_scores)}/{len(top1_scores)}\\\")\\n\",\n",
    "    \"print(f\\\"All-scores mean / std    : {df['score'].mean():.1f} / {df['score'].std():.1f}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"with open('all_match_results.json', 'w') as f:\\n\",\n",
    "    \"    json.dump(all_results, f, indent=2)\\n\",\n",
    "    \"print('\\\\nSaved all_match_results.json')\"\n",
    "   ]\n",
    "  }\n",
    " ],\n",
    " \"metadata\": {\n",
    "  \"kernelspec\": {\"display_name\": \"Python 3\", \"language\": \"python\", \"name\": \"python3\"},\n",
    "  \"language_info\": {\"name\": \"python\", \"version\": \"3.10.0\"}\n",
    " },\n",
